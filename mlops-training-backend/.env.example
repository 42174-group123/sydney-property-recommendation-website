# Supabase source database. Use the service role key for scheduled training so
# the backend can read all users' user_action rows through RLS.
SUPABASE_URL=https://rmonjbexchkyvkgecacn.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ClearML hosted web workspace. Keep real keys in `.env`, never in git.
ENABLE_CLEARML=true
CLEARML_WEB_HOST=https://app.clear.ml/
CLEARML_API_HOST=https://api.clear.ml
CLEARML_FILES_HOST=https://files.clear.ml
CLEARML_API_ACCESS_KEY=
CLEARML_API_SECRET_KEY=
CLEARML_OUTPUT_URI=
CLEARML_PROJECT_DATA=Stay Scout MLOps/Data Snapshots
CLEARML_PROJECT_REVIEW=Stay Scout MLOps/Review Score Rating
CLEARML_PROJECT_PREFERENCE=Stay Scout MLOps/User Preference
CLEARML_REUSE_TASKS=true

# Inference artifacts. The service tries ClearML first, then local paths.
PREFER_CLEARML_ARTIFACTS=true
FORCE_HEURISTIC_MODEL_FALLBACK=false
CLEARML_USE_LATEST_ARTIFACTS=true
CLEARML_REVIEW_TASK_ID=
CLEARML_PREFERENCE_TASK_ID=
CLEARML_REVIEW_TASK_NAME=Review Score Rating Training
CLEARML_PREFERENCE_TASK_NAME=User Preference Training
CLEARML_REVIEW_ARTIFACT_NAME=best_review_score_rating_model
CLEARML_PREFERENCE_ARTIFACT_NAME=best_user_preference_model
MODEL_CACHE_SECONDS=1800
REVIEW_MODEL_LOCAL_PATH=data/runs/clearml_full_20260522_02/review_score_rating/models/review_score_rating_model.joblib
PREFERENCE_MODEL_LOCAL_PATH=data/runs/clearml_full_20260522_02/user_preference/models/user_preference_model.joblib
LISTINGS_SNAPSHOT_LOCAL_PATH=data/runs/clearml_full_20260522_02/supabase_listings_snapshot.csv
RANKING_PREFER_LOCAL_SNAPSHOT=false
RANKING_FETCH_USER_ACTIONS=true
RANKING_USER_ACTION_CACHE_SECONDS=1800
RANKING_USER_ACTION_TIMEOUT_SECONDS=6
RANKING_LISTING_CACHE_SECONDS=300
MAX_RANKING_CANDIDATES=20000
PREFERENCE_SCORE_WEIGHT=0.6
REVIEW_SCORE_WEIGHT=0.4
CORS_ALLOW_ORIGINS=*

# Scheduler.
TRAIN_INTERVAL_MINUTES=30
ENABLE_SCHEDULER=true
RUN_ON_STARTUP=false

# Optional local synthetic seed events. They are canonicalised down to the real
# user_action contract before being merged with Supabase user_action rows.
INCLUDE_SYNTHETIC_EVENTS=true
SYNTHETIC_EVENTS_PATH=_source_artifacts/user_preference_model/synthetic_browsing_events.csv

# Training controls.
RANDOM_STATE=42
TEST_SIZE=0.2
CV_FOLDS=3
HPO_ITERATIONS=12
TRAIN_N_JOBS=1
LOKY_MAX_CPU_COUNT=1
MAX_TREE_ESTIMATORS=200
MAX_TABLE_ROWS=100000
PAGE_SIZE=1000
RETAIN_LOCAL_RUNS=false
UPLOAD_INPUT_SNAPSHOTS=false
MPLCONFIGDIR=/tmp/matplotlib
JOBLIB_TEMP_FOLDER=/tmp/joblib
