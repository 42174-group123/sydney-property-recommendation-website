# Supabase project used by the browser bundle.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Supabase project used by TanStack Start server functions.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Only needed if future server code imports supabaseAdmin.
SUPABASE_SERVICE_ROLE_KEY=

# ML ranking backend. Locally this is http://127.0.0.1:8090; in production,
# set this to the deployed API URL, for example https://stay-scout-ml-api.onrender.com.
ML_BACKEND_URL=http://127.0.0.1:8090

# Only needed when enabling Google OAuth in the local Supabase stack.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=
